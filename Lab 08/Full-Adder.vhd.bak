library IEEE;
use ieee.std_logic_1164.all;

entity somador_completo is
    port (
        a, b, cin : in std_logic;
        sum, cout : out std_logic
    );
end somador_completo;

architecture rtl of somador_completo is
begin
    sum <= a xor b xor cin;
    cout <= (cin and (a xor b)) or (a and b);
end rtl;